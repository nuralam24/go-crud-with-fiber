APP_ENV=dev
HTTP_ADDR=:8080
SHUTDOWN_TIMEOUT=10s
READ_TIMEOUT=5s
WRITE_TIMEOUT=5s
IDLE_TIMEOUT=60s

# Keep PgBouncer in front of PostgreSQL.
PG_DSN=postgresql://db_user:db_password@db-host:5432/go_crud?sslmode=require
PG_PING_TIMEOUT=15s
PG_PING_RETRIES=5
PG_PING_RETRY_DELAY=2s
PG_MAX_CONNS=120
PG_MIN_CONNS=20
PG_MAX_CONN_LIFETIME=15m
PG_MAX_CONN_IDLE_TIME=3m

JWT_SECRET=replace-with-32-char-secret

ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=12345
USER_EMAIL=user@gmail.com
USER_PASSWORD=12345

AUDIT_BUFFER_SIZE=8192
AUDIT_WORKERS=4
